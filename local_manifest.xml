<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <remote name="aehub"
            fetch="https://github.com/aepranata/"
            revision="android-13" />
    <remote name="ashub"
            fetch="ssh://git@github.com/aepranata/"
            revision="twelve" />
    <remote name="extrahub"
            fetch="https://github.com/" />
    <remote name="extralab"
            fetch="https://gitlab.com/" />

    <!-- Remove -->
    <remove-project name="android_vendor_banana" />

    <!-- Trees -->
    <project path="device/xiaomi/rosy" name="device_rosy" remote="ashub" clone-depth="1" />
    <project path="kernel/xiaomi/rosy" name="kernel_rosy" remote="ashub" revision="kuro" clone-depth="1" />
    <project path="vendor/xiaomi/rosy" name="vendor_rosy" remote="ashub" clone-depth="1" />
    
    <!-- Compiler -->
    <project path="prebuilts/gcc/linux-x86/aarch64/aarch64-elf" name="gcc-arm64" remote="aehub" revision="gcc-master" clone-depth="1" />
    <project path="prebuilts/gcc/linux-x86/arm/arm-eabi" name="gcc-arm" remote="aehub" revision="gcc-master" clone-depth="1" />
    
    <!-- Extra -->
    <project path="vendor/banana" name="vendor_banana" remote="aehub" revision="12" clone-depth="1" />
</manifest>
