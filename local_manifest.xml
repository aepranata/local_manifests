<?xml version="1.0" encoding="UTF-8"?>
<manifest>
    <remote name="aehub"
            fetch="https://github.com"
            revision="atiga-1.0" />
    <remote name="aelab"
            fetch="https://gitlab.com"
            revision="atiga-1.0-beta" />

    <!-- Remove -->
    <remove-project name="LineageOS/android_build" />
    <remove-project name="LineageOS/android_frameworks_base" />
    <remove-project name="LineageOS/android_frameworks_native" />
    <remove-project name="LineageOS/android_hardware_qcom_audio" />
    <remove-project name="LineageOS/android_packages_apps_DocumentsUI" />
    <remove-project name="LineageOS/android_packages_apps_LineageParts" />
    <remove-project name="LineageOS/android_packages_apps_Settings" />

    <!-- Trees -->
    <project path="device/xiaomi/rosy" name="aepranata/atiga_device_xiaomi_rosy" remote="aehub" clone-depth="1" />
    <project path="kernel/xiaomi/rosy" name="aepranata/atiga_kernel_xiaomi_rosy" remote="aehub" clone-depth="1" />
    <project path="vendor/xiaomi/rosy" name="aepranata/atiga_vendor_xiaomi_rosy" remote="aehub" clone-depth="1" />
    
    <!-- Compiler -->
    <project path="prebuilts/clang/host/linux-x86/clang-atiga" name="atiga-clang" remote="aelab" revision="13.x" clone-depth="1" />
    
    <!-- Extra -->
    <project path="build/make" name="Atiga/android_build" groups="pdk" remote="aelab" clone-depth="1">
        <copyfile src="core/root.mk" dest="Makefile" />
        <linkfile src="CleanSpec.mk" dest="build/CleanSpec.mk" />
        <linkfile src="buildspec.mk.default" dest="build/buildspec.mk.default" />
        <linkfile src="core" dest="build/core" />
        <linkfile src="envsetup.sh" dest="build/envsetup.sh" />
        <linkfile src="target" dest="build/target" />
        <linkfile src="tools" dest="build/tools" />
    </project>
    <project path="frameworks/base" name="Atiga/android_frameworks_base" groups="pdk-cw-fs,pdk-fs" remote="aelab" clone-depth="1" />
    <project path="frameworks/native" name="Atiga/android_frameworks_native" groups="pdk" remote="aelab" clone-depth="1" />
    <project path="hardware/qcom-caf/msm8998/audio" name="Atiga/android_hardware_qcom_audio" groups="qcom,qcom_audio,pdk-qcom" revision="atiga-1.0-caf-msm8998" remote="aelab" clone-depth="1" />
    <project path="packages/apps/DocumentsUI" name="Atiga/android_packages_apps_DocumentsUI" groups="pdk-cw-fs,pdk-fs" remote="aelab" clone-depth="1" />
    <project path="packages/apps/LineageParts" name="Atiga/android_packages_apps_LineageParts" remote="aelab" clone-depth="1" />
    <project path="packages/apps/Settings" name="Atiga/android_packages_apps_Settings" groups="pdk-fs" remote="aelab" clone-depth="1" />
</manifest>
